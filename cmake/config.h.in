/* config.h generated by CMake for the libpst-py extension build.
 * This replaces the autoconf-generated config.h for the Python packaging
 * path only; the autotools build is unaffected. */
#ifndef LIBPST_PY_CONFIG_H
#define LIBPST_PY_CONFIG_H

#cmakedefine HAVE_CTYPE_H 1
#cmakedefine HAVE_DIRENT_H 1
#cmakedefine HAVE_ERRNO_H 1
#cmakedefine HAVE_LIMITS_H 1
#cmakedefine HAVE_REGEX_H 1
#cmakedefine HAVE_SEMAPHORE_H 1
#cmakedefine HAVE_SIGNAL_H 1
#cmakedefine HAVE_STRING_H 1
#cmakedefine HAVE_SYS_IPC_H 1
#cmakedefine HAVE_SYS_SHM_H 1
#cmakedefine HAVE_SYS_STAT_H 1
#cmakedefine HAVE_SYS_TYPES_H 1
#cmakedefine HAVE_SYS_WAIT_H 1
#cmakedefine HAVE_UNISTD_H 1
#cmakedefine HAVE_WCHAR_H 1
#cmakedefine HAVE_ICONV 1
#cmakedefine HAVE_GET_CURRENT_DIR_NAME 1

/* iconv's second argument is (char **) on some platforms, (const char **) on
 * others. CMake decides which below. */
#cmakedefine ICONV_CONST @ICONV_CONST@

/* Large-file support: always use 64-bit file offsets. */
#ifndef _FILE_OFFSET_BITS
#define _FILE_OFFSET_BITS 64
#endif

#endif /* LIBPST_PY_CONFIG_H */
